{
    "components": {
        "schemas": {
            "handlers.DirectiveResponse": {
                "properties": {
                    "action": {
                        "type": "string"
                    },
                    "degrade_to": {
                        "type": "string"
                    },
                    "grace_period_ms": {
                        "type": "integer"
                    },
                    "id": {
                        "type": "string"
                    },
                    "payload": {
                        "type": "object"
                    },
                    "reason": {
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "handlers.ErrorResponse": {
                "properties": {
                    "error": {
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "handlers.EventResponse": {
                "properties": {
                    "attached": {
                        "type": "boolean"
                    },
                    "directive": {
                        "$ref": "#/components/schemas/handlers.DirectiveResponse"
                    },
                    "status": {
                        "type": "string"
                    }
                },
                "type": "object"
            }
        }
    },
    "info": {
        "description": "Receives sensor events and delivers directives to agents",
        "title": "Flightdeck Ingestion API",
        "version": "0.1.0"
    },
    "externalDocs": {
        "description": "",
        "url": ""
    },
    "paths": {
        "/health": {
            "get": {
                "description": "Returns service health status",
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "additionalProperties": {
                                        "type": "string"
                                    },
                                    "type": "object"
                                }
                            }
                        },
                        "description": "OK"
                    }
                },
                "summary": "Health check",
                "tags": [
                    "health"
                ]
            }
        },
        "/v1/events": {
            "post": {
                "description": "Validates bearer token, publishes event to NATS, returns directive envelope. On session_start events, also reports whether the session was attached to a pre-existing row (D094).",
                "parameters": [
                    {
                        "description": "Bearer token",
                        "in": "header",
                        "name": "Authorization",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object"
                            }
                        },
                        "text/plain": {
                            "schema": {
                                "title": "event",
                                "type": "object"
                            }
                        }
                    },
                    "description": "Event payload",
                    "required": true
                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/handlers.EventResponse"
                                }
                            }
                        },
                        "description": "OK"
                    },
                    "400": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/handlers.ErrorResponse"
                                }
                            }
                        },
                        "description": "Bad Request"
                    },
                    "401": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/handlers.ErrorResponse"
                                }
                            }
                        },
                        "description": "Unauthorized"
                    },
                    "429": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/handlers.ErrorResponse"
                                }
                            }
                        },
                        "description": "Too Many Requests"
                    },
                    "500": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/handlers.ErrorResponse"
                                }
                            }
                        },
                        "description": "Internal Server Error"
                    }
                },
                "summary": "Submit agent event",
                "tags": [
                    "events"
                ]
            }
        },
        "/v1/heartbeat": {
            "post": {
                "description": "Validates bearer token, publishes heartbeat to NATS, returns directive envelope",
                "parameters": [
                    {
                        "description": "Bearer token",
                        "in": "header",
                        "name": "Authorization",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object"
                            }
                        },
                        "text/plain": {
                            "schema": {
                                "title": "heartbeat",
                                "type": "object"
                            }
                        }
                    },
                    "description": "Heartbeat payload with session_id",
                    "required": true
                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "additionalProperties": {},
                                    "type": "object"
                                }
                            }
                        },
                        "description": "OK"
                    },
                    "400": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/handlers.ErrorResponse"
                                }
                            }
                        },
                        "description": "Bad Request"
                    },
                    "401": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/handlers.ErrorResponse"
                                }
                            }
                        },
                        "description": "Unauthorized"
                    },
                    "500": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/handlers.ErrorResponse"
                                }
                            }
                        },
                        "description": "Internal Server Error"
                    }
                },
                "summary": "Agent heartbeat",
                "tags": [
                    "heartbeat"
                ]
            }
        }
    },
    "openapi": "3.1.0",
    "servers": [
        {
            "url": "localhost:8080/"
        }
    ]
}