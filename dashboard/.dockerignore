# Anything in node_modules is regenerated by ``npm ci`` in the
# Dockerfile builder stage. Including the host's tracked
# node_modules in the build context overlays the freshly-installed
# tree with files whose execute bits do not survive the journey
# from a Windows checkout, which broke ``npm run build`` with
# ``exit 126`` (permission denied on node_modules/.bin/tsc) on the
# v0.2.0 release run. Excluding it here forces the Dockerfile to
# rely entirely on the in-image ``npm ci`` output.
node_modules

# Local build artifacts
dist
.vite

# Local test caches
coverage
.eslintcache
.vitest-cache

# Editor / VCS noise
.git
.gitignore
.idea
.vscode

# The Dockerfile copies its own context; do not ship the local
# Dockerfile / .dockerignore back into the build context recursively
Dockerfile
.dockerignore
