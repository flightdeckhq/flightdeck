{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/scripts/observe_cli.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/scripts/observe_cli.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node hooks/scripts/observe_cli.mjs"
      }
    ]
  }
}
