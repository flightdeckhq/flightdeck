*.egg
.venv/

# Go
bin/
tmp/

# Node
node_modules/
.vite/

# Helm
# helm/migrations/ is a build artifact populated by helm/Makefile
# sync-migrations from docker/postgres/migrations/ (the canonical
# source). Do not edit in place; edit the source under
# docker/postgres/migrations/ and re-run any chart-render target
# (lint / template / install / upgrade) which gates on
# sync-migrations. See DECISIONS.md D136.
helm/migrations/

# IDE
.idea/
.vscode/
*.iml
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Env
.env

# Production runtime config. Operators may mount their own
# runtime-config.json over /usr/share/nginx/html/runtime-config.json
# inside the dashboard container. The repo-shipped default at
# dashboard/public/runtime-config.json is the dev token; ignore any
# host-side override file so a deployer's production token never
# accidentally lands in source control.
runtime-config.prod.json
docker/dashboard/runtime-config.json
docker/runtime-config.json

# Claude
.claude/
tests/smoke/.venv-py312/

# Local scratch space + agent indices. Both are working scratchpads
# (probe screenshots, throwaway diffs, ChunkHound's local code-search
# index). They are per-developer artifacts and never belong in the
# tree.
.scratch/
.chunkhound/

# Playwright + go test outputs. Generated on every run; bulky and
# noisy in git status.
test-results/
playwright-report/
docker/test-results/
