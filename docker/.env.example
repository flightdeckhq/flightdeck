# Postgres
POSTGRES_USER=flightdeck
POSTGRES_PASSWORD=flightdeck_dev
POSTGRES_DB=flightdeck
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Ingestion API
FLIGHTDECK_INGESTION_PORT=8080
FLIGHTDECK_POSTGRES_URL=postgres://flightdeck:flightdeck_dev@postgres:5432/flightdeck?sslmode=disable
FLIGHTDECK_NATS_URL=nats://nats:4222
FLIGHTDECK_ENV=development
SHUTDOWN_TIMEOUT_SECS=30

# Workers
FLIGHTDECK_WORKER_POOL_SIZE=10

# Query API
FLIGHTDECK_API_PORT=8081
